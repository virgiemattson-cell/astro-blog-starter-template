---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  lang?: string;
  path?: string;
}

const { title, description, lang = "en", path = "/" } = Astro.props;
const siteUrl = "https://skyvisible.com";

// Build canonical URL based on language and logical path
const canonicalEn = `${siteUrl}${path === "/" ? "" : path}/`;
const canonicalUr = `${siteUrl}/urdu${path === "/" ? "" : path}/`;
const canonical = lang === "ur" ? canonicalUr : canonicalEn;
const altEn = canonicalEn;
const altUr = canonicalUr;
---

<!doctype html>
<html lang={lang === "ur" ? "ur" : "en"} dir={lang === "ur" ? "rtl" : "ltr"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    {/* ─── Canonical & Hreflang ─────────────────────── */}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={altEn} />
    <link rel="alternate" hreflang="ur" href={altUr} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    {lang === "ur" && (
      <style>
        @font-face {
          font-family: 'JameelNooriNastaleeq';
          src: url('/fonts/JameelNooriNastaleeq.woff') format('woff');
          font-display: swap;
        }
        body {
          font-family: 'JameelNooriNastaleeq', 'Inter', sans-serif !important;
          font-size: 20px;
          line-height: 2.4 !important;
        }
        h1, h2, h3, h4 {
          font-family: 'JameelNooriNastaleeq', 'Inter', sans-serif !important;
          letter-spacing: normal !important;
          line-height: 2 !important;
        }
        h1 { font-size: 2em; line-height: 2.2 !important; }
        h2 { font-size: 1.5em; line-height: 2 !important; }
        p { line-height: 2.4 !important; }
        .tag { font-size: 14px !important; line-height: 1.5 !important; }
        .hero h1 { line-height: 2.2 !important; }
        .hero p { line-height: 2.4 !important; }
        .service-card { padding: 28px 24px !important; }
        .service-card h3 { line-height: 2 !important; font-size: 1.15em !important; }
        .service-card p { line-height: 2.2 !important; }
        .why-text h2 { line-height: 2 !important; }
        .why-text > p { line-height: 2.4 !important; }
        .step-card { padding: 28px 20px !important; }
        .step-card h3 { line-height: 1.8 !important; }
        .step-card p { line-height: 2.2 !important; }
        .testimonial-card > p { line-height: 2.2 !important; }
        .testimonial-card { padding: 24px !important; }
        .nav-links a { font-size: 16px !important; }
        .card-features li { line-height: 2.2 !important; font-size: 15px !important; }
        .stat-item p { font-size: 15px !important; }
        .hero-content { max-width: 800px !important; }
      </style>
    )}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot name="navbar" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
    <slot name="whatsapp" />

    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          if (entry.target.classList.contains('fade-in')) {
            entry.target.classList.add('visible');
          }
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.15 });
      document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
