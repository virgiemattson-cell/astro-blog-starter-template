---
const { lang = "en" } = Astro.props;
const langHref = lang === "ur" ? "/" : "/urdu";
const langLabel = lang === "ur" ? "English" : "اردو";
---

<nav class="nav" id="navbar">
  <div class="container">
    <div class="nav-inner">
      <a href="/" class="logo">Sky<span>Visible</span></a>
      <ul class="nav-links">
        <li><a href="/">{lang === "ur" ? "ہوم" : "Home"}</a></li>
        <li><a href="/services">{lang === "ur" ? "خدمات" : "Services"}</a></li>
        <li><a href="/about">{lang === "ur" ? "ہمارے بارے میں" : "About"}</a></li>
        <li><a href="/contact">{lang === "ur" ? "رابطہ" : "Contact"}</a></li>
        <li><a href={langHref} class="lang-switch">{langLabel}</a></li>
      </ul>
      <a href="/contact" class="btn-nav">{lang === "ur" ? "مفت مشورہ →" : "Free Audit →"}</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 20px 0;
    transition: all 0.3s ease;
  }
  .nav.scrolled {
    background: rgba(6,12,29,0.94);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 14px 0;
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    font-size: 22px;
    font-weight: 800;
    text-decoration: none;
    color: var(--white);
    letter-spacing: -0.02em;
  }
  .logo span { color: var(--sky); }
  .nav-links {
    display: flex;
    gap: 36px;
    list-style: none;
  }
  .nav-links a {
    text-decoration: none;
    color: var(--muted);
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--white); }
  .lang-switch {
    background: rgba(255,255,255,0.06);
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 12px !important;
    font-weight: 600 !important;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .lang-switch:hover {
    background: rgba(255,255,255,0.12);
  }
  @media (max-width: 640px) {
    .nav-links { display: none; }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 50);
  });
</script>
