---
import { WHATSAPP_NUMBER, WHATSAPP_MESSAGE } from '../consts';
const { lang = "en" } = Astro.props;
const waUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(WHATSAPP_MESSAGE)}`;
---

<section class="cta-section" id="contact">
  <div class="container">
    <div class="tag">{lang === "ur" ? "محدود نشستیں" : "Limited Spots Available"}</div>
    <h2>{lang === "ur" ? "تیار ہیں؟<br><span class=\"glow\">نظر انداز کرنا ناممکن</span> بننے کے لیے؟" : "Ready to Be<br><span class=\"glow\">Impossible to Ignore?</span>"}</h2>
    <p>{lang === "ur" ? "مفت 30 منٹ کا مشورہ حاصل کریں — بغیر کسی ذمہ داری کے۔ ہم آپ کو دکھائیں گے کہ آپ کہاں گاہک کھو رہے ہیں اور اسے کیسے ٹھیک کریں۔" : "Get a free 30-minute audit — no strings attached. We'll show you exactly where you're losing clients and how to fix it fast."}</p>
    
    <div class="contact-cards">
      <a href={waUrl} target="_blank" rel="noopener" class="contact-wa-card">
        <div class="wa-icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="white">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </div>
        <div class="wa-text">
          <h3>{lang === "ur" ? "واٹس ایپ پر رابطہ کریں" : "Contact us on WhatsApp"}</h3>
          <p>{lang === "ur" ? "فوری جواب کے لیے واٹس ایپ پر میسج کریں" : "Message us on WhatsApp for a quick response"}</p>
          <span class="wa-btn">{lang === "ur" ? "واٹس ایپ کھولیں →" : "Open WhatsApp →"}</span>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    text-align: center;
    padding: 96px 0;
    position: relative;
    overflow: hidden;
  }
  .cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 70% 80% at 50% 50%, rgba(37,99,235,0.16) 0%, transparent 70%);
  }
  .cta-section h2 {
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
    position: relative;
  }
  .cta-section > .container > p {
    font-size: 17px;
    color: var(--muted);
    margin-bottom: 40px;
    position: relative;
  }
  .cta-section .tag { margin: 0 auto 24px; }
  
  .contact-cards {
    display: flex;
    justify-content: center;
    position: relative;
    z-index: 2;
  }
  .contact-wa-card {
    display: flex;
    align-items: center;
    gap: 24px;
    background: rgba(37,211,102,0.08);
    border: 1px solid rgba(37,211,102,0.3);
    border-radius: 20px;
    padding: 32px 40px;
    text-decoration: none;
    transition: all 0.3s ease;
    max-width: 500px;
    width: 100%;
  }
  .contact-wa-card:hover {
    background: rgba(37,211,102,0.15);
    border-color: rgba(37,211,102,0.5);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(37,211,102,0.2);
  }
  .wa-icon {
    width: 64px; height: 64px; background: #25D366;
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .wa-icon svg { width: 32px; height: 32px; }
  .wa-text { text-align: left; }
  .wa-text h3 { font-size: 18px; font-weight: 700; margin-bottom: 4px; color: var(--white); }
  .wa-text p { font-size: 13px; color: var(--muted); margin-bottom: 8px; }
  .wa-btn {
    display: inline-block;
    background: #25D366;
    color: #000;
    font-size: 13px;
    font-weight: 700;
    padding: 8px 16px;
    border-radius: 8px;
  }
</style>
