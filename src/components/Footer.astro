---
const { lang = "en" } = Astro.props;
const prefix = lang === "ur" ? "/urdu" : "";
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <a href={prefix || "/"} class="footer-logo">Sky<span>Visible</span></a>
      <ul class="footer-links">
        <li><a href={prefix || "/"}>{lang === "ur" ? "ہوم" : "Home"}</a></li>
        <li><a href={`${prefix}/services`}>{lang === "ur" ? "خدمات" : "Services"}</a></li>
        <li><a href={`${prefix}/about`}>{lang === "ur" ? "ہمارے بارے میں" : "About"}</a></li>
        <li><a href={`${prefix}/contact`}>{lang === "ur" ? "رابطہ" : "Contact"}</a></li>
      </ul>
      <p class="footer-copy">© 2025 SkyVisible. {lang === "ur" ? "جملہ حقوق محفوظ ہیں۔" : "All rights reserved."}</p>
    </div>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--border); padding: 48px 0; }
  .footer-inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; }
  .footer-logo { font-size: 18px; font-weight: 800; color: var(--white); text-decoration: none; }
  .footer-logo span { color: var(--sky); }
  .footer-links { display: flex; gap: 28px; list-style: none; flex-wrap: wrap; }
  .footer-links a { text-decoration: none; color: var(--muted); font-size: 13px; transition: color 0.2s; }
  .footer-links a:hover { color: var(--white); }
  .footer-copy { font-size: 12px; color: var(--muted); }
  @media (max-width: 640px) { .footer-inner { flex-direction: column; text-align: center; } }
</style>
