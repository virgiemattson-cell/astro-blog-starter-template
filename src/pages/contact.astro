---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import ContactForm from '../components/ContactForm.astro';
import { WHATSAPP_NUMBER } from '../consts';
import { SITE_TITLE } from '../consts';
---

<Layout title={`Contact — ${SITE_TITLE}`} description="Contact SkyVisible for a free digital marketing audit" path="/contact">
  <Navbar slot="navbar" />
  
  <section class="hero" style="min-height: auto; padding: 160px 0 80px;">
    <div class="container" style="text-align: center;">
      <div class="tag">Get In Touch</div>
      <h1 style="font-size: clamp(36px, 5vw, 56px); font-weight: 800; margin-bottom: 16px;">
        Let's Grow Your<br><span class="glow">Business Together</span>
      </h1>
      <p style="color: var(--muted); max-width: 500px; margin: 0 auto 48px; font-size: 17px;">
        Ready to dominate your market? Message us on WhatsApp and we'll get back to you within minutes.
      </p>
      <a href={`https://wa.me/${WHATSAPP_NUMBER}`} target="_blank" rel="noopener" class="btn-primary" style="font-size: 18px; padding: 16px 36px;">
        💬 Chat on WhatsApp
      </a>
      <p style="color: var(--muted); font-size: 14px; margin-top: 16px;">
        Response time: &lt; 5 minutes during business hours
      </p>
    </div>
  </section>
  
  <Footer slot="footer" />
  <WhatsAppButton slot="whatsapp" />
</Layout>
