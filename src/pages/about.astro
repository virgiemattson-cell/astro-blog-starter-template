---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import WhyUs from '../components/WhyUs.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE_TITLE } from '../consts';
---

<Layout title={`About — ${SITE_TITLE}`} description="Learn more about SkyVisible digital marketing agency">
  <Navbar slot="navbar" />
  
  <section class="hero" style="min-height: auto; padding: 160px 0 80px;">
    <div class="container" style="text-align: center;">
      <div class="tag">About Us</div>
      <h1 style="font-size: clamp(36px, 5vw, 56px); font-weight: 800; margin-bottom: 16px;">
        Pakistan's Premier<br><span class="glow">Digital Growth Agency</span>
      </h1>
      <p style="color: var(--muted); max-width: 600px; margin: 0 auto; font-size: 17px; line-height: 1.8;">
        SkyVisible was founded with a simple mission: help local businesses in Pakistan dominate 
        the digital space. We combine global best practices with local market expertise to deliver 
        real, measurable results — not just vanity metrics.
      </p>
    </div>
  </section>
  
  <WhyUs />
  <ContactForm />
  <Footer slot="footer" />
  <WhatsAppButton slot="whatsapp" />
</Layout>
